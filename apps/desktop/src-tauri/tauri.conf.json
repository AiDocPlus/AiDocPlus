{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "AiDocPlus",
  "version": "0.3.4",
  "identifier": "com.aidocplus.app",
  "build": {
    "beforeDevCommand": "cd src-ui && pnpm dev",
    "beforeBuildCommand": "cd src-ui && pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "AiDocPlus - AI Document Editor",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "resources": ["bundled-resources/"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": "Developer ID Application: 德华 江 (3VA3JP25LX)"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5NjNCQjAwNjEzNkE5ODEKUldTQnFUWmhBTHRqNllsSmw4L3lnZExDTXpiWG5nTkRJa2hHM2dEcFdobytkaU45VGJicEVhY3MK",
      "endpoints": [
        "https://github.com/AiDocPlus/AiDocPlus/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "cli": {
      "description": "AiDocPlus 命令行工具",
      "args": [
        {
          "name": "version",
          "short": "v",
          "description": "显示版本号",
          "takesValue": false
        }
      ],
      "subcommands": {
        "api": {
          "description": "API 相关操作",
          "subcommands": {
            "status": {
              "description": "查看 API Server 状态"
            },
            "schema": {
              "description": "查看 API Schema"
            },
            "call": {
              "description": "调用 API 方法",
              "args": [
                {
                  "name": "method",
                  "description": "API 方法名（如 document.list）",
                  "index": 1,
                  "required": true,
                  "takesValue": true
                },
                {
                  "name": "params",
                  "short": "p",
                  "description": "JSON 参数",
                  "takesValue": true
                }
              ]
            }
          }
        }
      }
    },
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["aidocplus"]
      }
    }
  }
}
